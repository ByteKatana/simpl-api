#URL
BASE_URL=http://DOMAIN:3000

#DATABASE
#MONGODB_CONNECTION_STRING and PRISMA_DB_URL must be the same.
#MONGODB_CONNECTION_STRING will be removed once we completely migrate to Prisma
MONGODB_CONNECTION_STRING=mongodb://DB_USERNAME:DB_USER_PW@DOMAIN:27017/DB_NAME?serverSelectionTimeoutMS=5000&connectTimeoutMS=10000
PRISMA_DB_URL=mongodb://DB_USERNAME:DB_USER_PW@DOMAIN:27017/DB_NAME?serverSelectionTimeoutMS=5000&connectTimeoutMS=10000
DB_NAME=

#KEYS & SECRETS
#API_KEY will be generated by the server during the setup process
API_KEY=
SECRET_KEY=
NEXTAUTH_SECRET=
AUTH_SECRET=
AUTH_TRUST_HOST=true

#OAUTH PROVIDERS
AUTH_GOOGLE_ID={CLIENT_ID}
AUTH_GOOGLE_SECRET={CLIENT_SECRET}
AUTH_[PROVIDER_NAME]_SECRET={CLIENT_SECRET}

#MAIL SERVER
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=


#TESTING
TEST_MONGODB_CONNECTION_STRING=mongodb://DB_USERNAME:DB_USER_PW@DOMAIN:27017/TEST_DB_NAME?serverSelectionTimeoutMS=5000&connectTimeoutMS=10000
TEST_DB_NAME=