generator client {
  provider = "prisma-client"
  output   = "../prisma-client"
}

datasource db {
  provider = "mongodb"
  url      = env("PRISMA_DB_URL")
}

model settings {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  name       String
  settings   Json
  updated_at DateTime
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String // This will store the user's email
  token      String   @unique
  expires    DateTime
  type       String?  @default("REGISTRATION") //REGISTRATION or MAGIC_LINK
  createdAt  DateTime @default(now())

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model ApiRequestLog {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  endpoint      String
  apiKey        String
  responseTime  Int
  ipAddress     String
  isRateLimited Boolean
  rateLimitType String   @default("")
  timestamp     DateTime @default(now())

  @@map("api_logs")
}

model ApiKey {
  id  String @id @default(auto()) @map("_id") @db.ObjectId
  key String

  @@map("api_keys")
  @@ignore
}

model Entry {
  id         String @id @default(auto()) @map("_id") @db.ObjectId
  data       Json
  name       String
  namespace  String
  slug       String
  status     String
  updated_at String

  @@map("entries")
  @@ignore
}

model EntryType {
  id         String  @id @default(auto()) @map("_id") @db.ObjectId
  createdBy  String
  created_at String?
  fieldsets  Json
  name       String
  namespace  String
  slug       String
  status     String
  updated_at String?

  @@map("entry_types")
}

model PermissionGroup {
  id         String @id @default(auto()) @map("_id") @db.ObjectId
  name       String
  privileges Json
  slug       String

  @@map("permission_groups")
}

model User {
  id               String  @id @default(auto()) @map("_id") @db.ObjectId
  email            String
  fullname         String
  password         String
  permission_group String
  profile_img      String
  status           String
  username         String
  email_verified   Boolean
  created_at       String?
  created_by       String?
  updated_at       String?
  updated_by       String?

  @@map("users")
}
